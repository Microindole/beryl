// Runtime smoke case: match lowering supports enum payload and nested enum payload patterns.
// @expect-exit: 0

enum Payload {
  Num(int),
  Text(string)
}

enum Message {
  Quit,
  Wrap(Payload),
  Pair(int, int),
  Triple(int, int, Payload)
}

var p = Pair(5, 6)
var first = match (p) {
  Pair(n, _) => n,
  _ => 0
}

if first != 5 {
  return 8
}

var m = Wrap(Num(7))
var code = match (m) {
  Quit => 9,
  Wrap(Num(v)) if (v == 7) => 0,
  Wrap(Text(msg)) => 6,
  _ => 5
}

if code != 0 {
  return code
}

var t = Triple(1, 2, Num(9))
var nested = match (t) {
  Triple(1, _, Num(v)) => v,
  Triple(a, b, Text(msg)) => a + b,
  _ => 4
}

if nested != 9 {
  return nested
}

return 0
