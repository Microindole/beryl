// Runtime smoke case: selfhost codegen wires file_exists/is_dir builtins through Rust LIR backend.
// @expect-exit: 0

var existing_file = file_exists("assets/Lency.txt")
if !existing_file {
    return 11
}

var existing_dir = is_dir("assets")
if !existing_dir {
    return 12
}

var missing_file = file_exists("assets/__lency_missing__.txt")
if missing_file {
    return 13
}

var file_is_dir = is_dir("assets/Lency.txt")
if file_is_dir {
    return 14
}

return 0
