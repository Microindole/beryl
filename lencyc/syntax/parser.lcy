// lencyc/syntax/parser.lcy
// Lency Self-hosted Compiler - Recursive Descent Parser
// Currently handles basic math and variable declarations.

import std.core
import lencyc.syntax.token
import lencyc.syntax.lexer
import lencyc.syntax.ast
import lencyc.syntax.parser.expr
import lencyc.syntax.parser.stmt
import lencyc.syntax.parser.decl

struct Parser {
    Lexer lexer
    Token current
    Token previous
    bool has_error
    int error_count
    int loop_depth
    bool signature_only
    bool suppress_error_output
    Vec<Vec<string>> queued_import_paths
}

Parser make_parser(string source) {
    var lexer = make_lexer(source)
    return Parser {
        lexer: lexer,
        current: make_token(0, "", 0, 0),
        previous: make_token(0, "", 0, 0),
        has_error: false,
        error_count: 0,
        loop_depth: 0,
        signature_only: false,
        suppress_error_output: false,
        queued_import_paths: vec![]
    }
}

impl Parser {
    string format_error(string message) {
        return "Error at " + int_to_string(this.current.line) + ":" + int_to_string(this.current.column) + ": " + message
    }

    void error(string message) {
        if !this.suppress_error_output {
            print(this.format_error(message) + "\n")
        }
        this.has_error = true
        this.error_count = this.error_count + 1
    }
    
    void advance() {
        this.previous = this.current
        
        while true {
            this.current = this.lexer.scan_token()
            if this.current.kind != T_ERROR() {
                break
            }
            this.error(this.current.lexeme)
        }
    }
    
    void consume(int type, string message) {
        if this.current.kind == type {
            this.advance()
            return
        }
        this.error(message)
    }
    
    bool check(int type) {
        return this.current.kind == type
    }
    
    bool match_token(int type) {
        if !this.check(type) {
            return false
        }
        this.advance()
        return true
    }

    bool is_signature_type_token(int kind) {
        return kind == T_INT() || kind == T_STRING() || kind == T_BOOL() || kind == T_VOID() || kind == T_FLOAT() || kind == T_IDENTIFIER()
    }

    bool parse_generic_type_ref_inner(bool report_error) {
        if !this.is_signature_type_token(this.current.kind) {
            if report_error {
                this.error("Expect type in generic arguments.")
            }
            return false
        }
        this.advance()
        if this.check(T_LESS()) {
            if !this.consume_generic_type_arguments(report_error) {
                return false
            }
        }
        if this.match_token(T_QUESTION()) {
            // Optional nullable suffix in generic argument.
        }
        if this.match_token(T_BANG()) {
            // Optional non-null assertion suffix in generic argument.
        }
        return true
    }

    bool consume_generic_type_arguments(bool report_error) {
        if !this.match_token(T_LESS()) {
            return false
        }
        if !this.parse_generic_type_ref_inner(report_error) {
            return false
        }
        while this.match_token(T_COMMA()) {
            if !this.parse_generic_type_ref_inner(report_error) {
                return false
            }
        }
        if !this.match_token(T_GREATER()) {
            if report_error {
                this.error("Expect '>' after generic type arguments.")
            }
            return false
        }
        return true
    }

    bool is_generic_call_ahead() {
        // FIXME: This is a conservative text-level lookahead; very complex relational chains
        // like `a < b > (c)` may still be misclassified before full type-aware parsing exists.
        if this.current.kind != T_LESS() {
            return false
        }
        var src = this.lexer.source
        var idx = this.lexer.current
        var depth = 1
        var has_type_head = false
        while idx < len(src) {
            var b = src[idx]
            if b == 32 || b == 9 || b == 10 || b == 13 { // whitespace
                idx = idx + 1
                continue
            }
            if b == 60 { // '<'
                depth = depth + 1
                idx = idx + 1
                continue
            }
            if b == 62 { // '>'
                depth = depth - 1
                idx = idx + 1
                if depth == 0 {
                    break
                }
                continue
            }
            var is_alpha_num = is_alphanumeric(b)
            var is_allowed_symbol = b == 95 || b == 44 || b == 63 || b == 33 || b == 46 // _ , ? ! .
            if !is_alpha_num && !is_allowed_symbol {
                return false
            }
            if !has_type_head {
                has_type_head = is_alpha(b) || b == 95
            }
            idx = idx + 1
        }
        if depth != 0 || !has_type_head {
            return false
        }
        while idx < len(src) {
            var b2 = src[idx]
            if b2 == 32 || b2 == 9 || b2 == 10 || b2 == 13 {
                idx = idx + 1
                continue
            }
            return b2 == 40 // '('
        }
        return false
    }

    void skip_generic_type_arguments_if_any() {
        if this.check(T_LESS()) {
            this.consume_generic_type_arguments(true)
        }
    }

    Program parse_program() {
        var statements = vec![]
        var decls = vec![]
        this.advance() // 启动 parser
        
        while !this.is_at_end() {
            var before_error_count = this.error_count
            var stmt = make_stmt_block(vec![])
            if this.queued_import_paths.len() > 0 {
                stmt = make_stmt_import(this.queued_import_paths.pop())
            } else {
                stmt = this.declaration()
            }
            statements.push(stmt)
            if is_declaration_stmt(stmt) {
                if has_decl_payload_mismatch(stmt) {
                    this.error(
                        "internal declaration payload mismatch: stmt kind " +
                        int_to_string(stmt.kind) +
                        ", decl kind " +
                        int_to_string(stmt.decl.kind)
                    )
                } else {
                    decls.push(stmt_to_decl(stmt))
                }
            }
            if this.error_count > before_error_count {
                this.synchronize()
            }
        }
        return make_program(decls, statements)
    }
    
    bool is_at_end() {
        return this.current.kind == T_EOF()
    }

    // Recover to next plausible statement boundary after a parse error.
    void synchronize() {
        while !this.is_at_end() {
            if this.current.kind == T_VAR() || this.current.kind == T_CONST() || this.current.kind == T_IF() || this.current.kind == T_WHILE() || this.current.kind == T_FOR() || this.current.kind == T_RETURN() || this.current.kind == T_BREAK() || this.current.kind == T_CONTINUE() || this.current.kind == T_STRUCT() || this.current.kind == T_IMPL() || this.current.kind == T_IMPORT() || this.current.kind == T_EXTERN() || this.current.kind == T_ENUM() || this.current.kind == T_TRAIT() || this.current.kind == T_MATCH() || this.current.kind == T_IDENTIFIER() || this.is_function_return_type_start() {
                return
            }
            this.advance()
        }
    }

    bool had_error() {
        return this.error_count > 0
    }
}
