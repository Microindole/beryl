// lencyc/cli/args.lcy
// 命令行参数处理模块

import std.core
import std.str

struct Args {
    string input_file
    string output_file
    bool check_only
}

bool is_option(string arg) {
    return starts_with(arg, "-")
}

string parse_inline_value(string arg, string prefix) {
    if !starts_with(arg, prefix) {
        return ""
    }
    return substr(arg, len(prefix), len(arg) - len(prefix))
}

// 解析命令行参数：
//   lencyc <input_file> [-o <output_file>] [--check-only]
//   lencyc <input_file> [--output=<output_file>] [--check-only]
Args parse_args() {
    var input_file = ""
    var output_file = "lencyc_selfhost_ast.txt"
    var check_only = false

    var argc = arg_count()
    var i = 1
    while i < argc {
        var arg = arg_at(i)

        if arg == "--check-only" {
            check_only = true
            i = i + 1
            continue
        }

        if arg == "-o" || arg == "--output" {
            if i + 1 >= argc {
                return Args { input_file: "", output_file: output_file, check_only: check_only }
            }
            output_file = arg_at(i + 1)
            i = i + 2
            continue
        }

        var short_inline = parse_inline_value(arg, "-o=")
        if short_inline != "" {
            output_file = short_inline
            i = i + 1
            continue
        }

        var long_inline = parse_inline_value(arg, "--output=")
        if long_inline != "" {
            output_file = long_inline
            i = i + 1
            continue
        }

        if is_option(arg) {
            i = i + 1
            continue
        }

        if input_file == "" {
            input_file = arg
        }
        i = i + 1
    }

    return Args {
        input_file: input_file,
        output_file: output_file,
        check_only: check_only
    }
}
