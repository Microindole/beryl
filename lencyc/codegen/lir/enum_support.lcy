// lencyc/codegen/lir/enum_support.lcy
// Enum metadata and constructor/type tracking for self-host LIR emission.

import std.core
import lencyc.syntax.ast
import lencyc.codegen.lir

impl LirBuilder {
    void preload_function_metadata(Vec<Stmt> statements) {
        var i = 0
        while i < statements.len() {
            var stmt = statements[i]
            if stmt.kind == STMT_FUNCTION() {
                var decl = stmt_to_decl(stmt)
                this.function_names.push(decl.name.lexeme)
                this.function_return_type_names.push(decl.return_type.name)
                this.function_param_counts.push(decl.params.len())
                var p = 0
                while p < decl.params.len() {
                    this.function_param_names.push(decl.params[p])
                    this.function_param_type_names.push(decl.param_types[p].name)
                    p = p + 1
                }
            }
            i = i + 1
        }
    }

    string lookup_function_return_type_name(string name) {
        var i = this.function_names.len() - 1
        while i >= 0 {
            if this.function_names[i] == name {
                return this.function_return_type_names[i]
            }
            i = i - 1
        }
        return ""
    }

    void preload_struct_metadata(Vec<Stmt> statements) {
        var i = 0
        while i < statements.len() {
            var stmt = statements[i]
            if stmt.kind == STMT_STRUCT() {
                var decl = stmt_to_decl(stmt)
                var f = 0
                while f < decl.struct_fields.len() {
                    this.struct_field_struct_names.push(decl.name.lexeme)
                    this.struct_field_names.push(decl.struct_fields[f].name.lexeme)
                    this.struct_field_indices.push(f)
                    this.struct_field_type_names.push(decl.struct_fields[f].type_ref.name)
                    f = f + 1
                }
            }
            i = i + 1
        }
    }

    void preload_enum_metadata(Vec<Stmt> statements) {
        var i = 0
        while i < statements.len() {
            var stmt = statements[i]
            if stmt.kind == STMT_ENUM() {
                var decl = stmt_to_decl(stmt)
                var tag_id = 0
                while tag_id < decl.enum_variants.len() {
                    this.enum_variant_enum_names.push(decl.name.lexeme)
                    this.enum_variant_names.push(decl.enum_variants[tag_id].name)
                    this.enum_variant_tags.push(tag_id)
                    var payload_id = 0
                    while payload_id < decl.enum_variants[tag_id].payload_types.len() {
                        this.enum_payload_enum_names.push(decl.name.lexeme)
                        this.enum_payload_variant_names.push(decl.enum_variants[tag_id].name)
                        this.enum_payload_indices.push(payload_id)
                        this.enum_payload_type_names.push(decl.enum_variants[tag_id].payload_types[payload_id].name)
                        payload_id = payload_id + 1
                    }
                    tag_id = tag_id + 1
                }
            }
            i = i + 1
        }
    }

    int lookup_enum_variant_index(string variant_name) {
        var i = this.enum_variant_names.len() - 1
        while i >= 0 {
            if this.enum_variant_names[i] == variant_name {
                return i
            }
            i = i - 1
        }
        return -1
    }

    string lookup_enum_name_by_variant(string variant_name) {
        var idx = this.lookup_enum_variant_index(variant_name)
        if idx < 0 {
            return ""
        }
        return this.enum_variant_enum_names[idx]
    }

    bool is_enum_type_name(string type_name) {
        if type_name == "" {
            return false
        }
        var i = this.enum_variant_enum_names.len() - 1
        while i >= 0 {
            if this.enum_variant_enum_names[i] == type_name {
                return true
            }
            i = i - 1
        }
        return false
    }

    bool is_enum_variant_in(string enum_name, string variant_name) {
        var i = this.enum_variant_names.len() - 1
        while i >= 0 {
            if this.enum_variant_enum_names[i] == enum_name && this.enum_variant_names[i] == variant_name {
                return true
            }
            i = i - 1
        }
        return false
    }

    int lookup_enum_tag_in(string enum_name, string variant_name) {
        var i = this.enum_variant_names.len() - 1
        while i >= 0 {
            if this.enum_variant_enum_names[i] == enum_name && this.enum_variant_names[i] == variant_name {
                return this.enum_variant_tags[i]
            }
            i = i - 1
        }
        return -1
    }

    string lookup_enum_payload_type_name_in(string enum_name, string variant_name, int payload_index) {
        var i = this.enum_payload_variant_names.len() - 1
        while i >= 0 {
            if this.enum_payload_enum_names[i] == enum_name &&
                this.enum_payload_variant_names[i] == variant_name &&
                this.enum_payload_indices[i] == payload_index {
                return this.enum_payload_type_names[i]
            }
            i = i - 1
        }
        return ""
    }

    void track_enum_variable(string name, string enum_name) {
        this.enum_var_names.push(name)
        this.enum_var_types.push(enum_name)
    }

    void clear_enum_variable(string name) {
        this.enum_var_names.push(name)
        this.enum_var_types.push("")
    }

    string lookup_enum_variable(string name) {
        var i = this.enum_var_names.len() - 1
        while i >= 0 {
            if this.enum_var_names[i] == name {
                return this.enum_var_types[i]
            }
            i = i - 1
        }
        return ""
    }

    void track_typed_variable(string name, string type_name) {
        this.typed_var_names.push(name)
        this.typed_var_types.push(type_name)
    }

    void clear_typed_variable(string name) {
        this.typed_var_names.push(name)
        this.typed_var_types.push("")
    }

    string lookup_typed_variable(string name) {
        var i = this.typed_var_names.len() - 1
        while i >= 0 {
            if this.typed_var_names[i] == name {
                return this.typed_var_types[i]
            }
            i = i - 1
        }
        return ""
    }

    int lookup_struct_field_index(string struct_name, string field_name) {
        var i = this.struct_field_names.len() - 1
        while i >= 0 {
            if this.struct_field_struct_names[i] == struct_name &&
               this.struct_field_names[i] == field_name {
                return this.struct_field_indices[i]
            }
            i = i - 1
        }
        return -1
    }

    string lookup_struct_field_type_name(string struct_name, string field_name) {
        var i = this.struct_field_names.len() - 1
        while i >= 0 {
            if this.struct_field_struct_names[i] == struct_name &&
               this.struct_field_names[i] == field_name {
                return this.struct_field_type_names[i]
            }
            i = i - 1
        }
        return ""
    }

    string expr_callee_name(Expr expr) {
        if expr.kind == EXPR_VARIABLE() {
            return expr.literal_value.lexeme
        }
        if expr.kind == EXPR_GROUPING() && expr.children.len() > 0 {
            return this.expr_callee_name(expr.children[0])
        }
        return ""
    }

    string infer_expr_enum_name(Expr expr) {
        if expr.kind == EXPR_VARIABLE() {
            return this.lookup_enum_variable(expr.literal_value.lexeme)
        }
        if expr.kind == EXPR_GROUPING() && expr.children.len() > 0 {
            return this.infer_expr_enum_name(expr.children[0])
        }
        if expr.kind == EXPR_ASSIGN() && expr.children.len() > 0 {
            return this.infer_expr_enum_name(expr.children[0])
        }
        if expr.kind == EXPR_CALL() && expr.children.len() > 0 {
            var callee_name = this.expr_callee_name(expr.children[0])
            if callee_name != "" {
                return this.lookup_enum_name_by_variant(callee_name)
            }
        }
        return ""
    }

    string infer_expr_type_name(Expr expr) {
        if expr.kind == EXPR_LITERAL() {
            if expr.literal_value.kind == T_STRING_LITERAL() {
                return "string"
            }
            if expr.literal_value.kind == T_NUMBER() {
                return "int"
            }
            if expr.literal_value.kind == T_TRUE() || expr.literal_value.kind == T_FALSE() {
                return "bool"
            }
            if expr.literal_value.kind == T_CHAR_LITERAL() {
                return "char"
            }
            if expr.literal_value.kind == T_NULL() {
                return "null"
            }
            return ""
        }
        if expr.kind == EXPR_VARIABLE() {
            var enum_name = this.lookup_enum_variable(expr.literal_value.lexeme)
            if enum_name != "" {
                return enum_name
            }
            return this.lookup_typed_variable(expr.literal_value.lexeme)
        }
        if expr.kind == EXPR_GROUPING() && expr.children.len() > 0 {
            return this.infer_expr_type_name(expr.children[0])
        }
        if expr.kind == EXPR_ASSIGN() && expr.children.len() > 0 {
            return this.infer_expr_type_name(expr.children[0])
        }
        if expr.kind == EXPR_CALL() && expr.children.len() > 0 {
            var enum_name2 = this.infer_expr_enum_name(expr)
            if enum_name2 != "" {
                return enum_name2
            }
            var callee_name = this.expr_callee_name(expr.children[0])
            if callee_name != "" {
                return this.lookup_function_return_type_name(callee_name)
            }
        }
        if expr.kind == EXPR_STRUCT() {
            return expr.literal_value.lexeme
        }
        if expr.kind == EXPR_SET() && expr.children.len() >= 2 {
            return this.infer_expr_type_name(expr.children[1])
        }
        if expr.kind == EXPR_GET() && expr.children.len() > 0 {
            var object_ty = this.infer_expr_type_name(expr.children[0])
            if object_ty != "" {
                return this.lookup_struct_field_type_name(object_ty, expr.literal_value.lexeme)
            }
        }
        return ""
    }
}
