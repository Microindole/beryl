// lencyc/sema/resolver/program.lcy
// Program/Decl-oriented resolver preload helpers for transitional architecture.

import std.core
import lencyc.syntax.ast
import lencyc.sema.resolver

impl Resolver {
    void preload_program_declarations(Vec<Decl> decls) {
        var i = 0
        while i < decls.len() {
            var decl = decls[i]
            if decl.kind == DECL_STRUCT() || decl.kind == DECL_ENUM() {
                if this.table.is_defined_in_current_scope(decl.name.lexeme) {
                    this.error("duplicate type in same scope: " + decl.name.lexeme)
                } else {
                    this.table.define(decl.name.lexeme)
                    if decl.kind == DECL_ENUM() {
                        this.preload_enum_type_name(decl.name.lexeme)
                    }
                }
            }
            i = i + 1
        }

        var e = 0
        while e < decls.len() {
            var decl = decls[e]
            if decl.kind == DECL_STRUCT() {
                var sf = 0
                while sf < decl.struct_fields.len() {
                    var field = decl.struct_fields[sf]
                    this.struct_field_signatures.push(
                        make_struct_field_signature(
                            decl.name.lexeme,
                            field.name.lexeme,
                            this.resolve_signature_type_or_error(field.type_ref),
                            this.resolve_signature_type_name(field.type_ref)
                        )
                    )
                    sf = sf + 1
                }
            }
            if decl.kind == DECL_ENUM() {
                var v = 0
                while v < decl.enum_variants.len() {
                    var variant = decl.enum_variants[v]
                    if this.table.is_defined_in_current_scope(variant.name) {
                        this.error("duplicate EnumConstructor in same scope: " + variant.name)
                        v = v + 1
                        continue
                    }
                    this.table.define(variant.name)
                    var payload_tys = vec![]
                    var payload_ty_names = vec![]
                    var p = 0
                    while p < variant.payload_types.len() {
                        payload_tys.push(this.resolve_signature_type_or_error(variant.payload_types[p]))
                        payload_ty_names.push(this.resolve_signature_type_name(variant.payload_types[p]))
                        p = p + 1
                    }
                    this.preload_enum_variant_signature(decl.name.lexeme, variant.name, payload_tys, payload_ty_names)
                    v = v + 1
                }
            }
            e = e + 1
        }

        var j = 0
        while j < decls.len() {
            var decl = decls[j]
            if decl.kind == DECL_FUNCTION() || decl.kind == DECL_EXTERN() {
                if this.table.is_defined_in_current_scope(decl.name.lexeme) {
                    this.error("duplicate function in same scope: " + decl.name.lexeme)
                } else {
                    this.table.define(decl.name.lexeme)
                    this.preload_builtin_arity(decl.name.lexeme, decl.params.len())
                    var param_tys = vec![]
                    var param_ty_names = vec![]
                    var k = 0
                    while k < decl.param_types.len() {
                        param_tys.push(this.resolve_signature_type_or_error(decl.param_types[k]))
                        param_ty_names.push(this.resolve_signature_type_name(decl.param_types[k]))
                        k = k + 1
                    }
                    this.function_signatures.push(
                        make_function_signature(
                            decl.name.lexeme,
                            this.resolve_signature_type_or_error(decl.return_type),
                            param_tys,
                            this.resolve_signature_type_name(decl.return_type),
                            param_ty_names,
                            this.resolve_signature_enum_name_or_empty(decl.return_type)
                        )
                    )
                }
            }
            if decl.kind == DECL_UNKNOWN() {
                this.error("unsupported declaration kind in preload: DECL_UNKNOWN")
            }
            j = j + 1
        }
    }
}
